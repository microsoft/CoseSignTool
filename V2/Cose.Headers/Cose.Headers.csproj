<Project Sdk="Microsoft.NET.Sdk">

    <!--Build configuration-->
    <PropertyGroup>
        <TargetFrameworks>netstandard2.0;net10.0</TargetFrameworks>
        <RootNamespace>Cose.Headers</RootNamespace>
    </PropertyGroup>

    <!--NuGet package configuration-->
    <PropertyGroup>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <Description>Generic COSE header implementations including CWT Claims (RFC 8392). Independent of COSE Sign1.</Description>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="System.Security.Cryptography.Cose" />
        <PackageReference Include="System.Formats.Cbor" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Cose.Abstractions\Cose.Abstractions.csproj" />
    </ItemGroup>

    <!--Files to include in the package-->
    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\" />
    </ItemGroup>

</Project>

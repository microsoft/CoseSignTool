<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>CoseSign1.AzureCodeSigning</id>
    <version>$VersionNgt$</version>
    <authors>Microsoft</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>
Implementation of ICoseSign1CertificateProvider for Azure Code Signing service to integrate with CoseSign1.
    </description>
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Azure.CodeSigning.Client.CryptoProvider" version="0.1.16" />
        <dependency id="CoseSign1.Certificates" version="$VersionNgt$" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="..\CoseSign1.AzureCodeSigning\bin\Release\netstandard2.0\CoseSign1.AzureCodeSigning.dll" target="lib\netstandard2.0" />
    <file src="..\CoseSign1.AzureCodeSigning\bin\Release\netstandard2.0\CoseSign1.AzureCodeSigning.pdb" target="Build\symbols" />
    <file src="..\CoseSign1.AzureCodeSigning\bin\Release\netstandard2.0\_manifest\spdx_2.2\manifest.cat" target="Build\sbom\spdx_2.2" />
    <file src="..\CoseSign1.AzureCodeSigning\bin\Release\netstandard2.0\_manifest\spdx_2.2\bsi.json" target="Build\sbom\spdx_2.2" />
    <file src="..\CoseSign1.AzureCodeSigning\bin\Release\netstandard2.0\_manifest\spdx_2.2\manifest.spdx.json" target="Build\sbom\spdx_2.2" />
    <file src="..\CoseSign1.AzureCodeSigning\bin\Release\netstandard2.0\_manifest\spdx_2.2\manifest.spdx.json.sha256" target="Build\sbom\spdx_2.2" />
  </files>
</package>
